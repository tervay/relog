    "lint": "oxlint -c oxlint.config.ts"
  },
  "devDependencies": {
    "@relog/config": "workspace:*",
    "unplugin-dts": "1.0.2",
    "vite": "8.0.16",
    "typescript": "6.0.3"
  }
}
