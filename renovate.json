{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "minimumReleaseAge": "72 hours",
  "schedule": ["every hour"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["every hour"]
  },
  "packageRules": [
    {
      "description": "Group Next.js and React runtime bumps together",
      "matchManagers": ["npm"],
      "matchPackageNames": ["next", "react", "react-dom"],
      "groupName": "frontend framework"
    },
    {
      "description": "Group TypeScript compiler and type definition bumps together",
      "matchManagers": ["npm"],
      "matchPackageNames": ["typescript", "/^@types\\//"],
      "groupName": "typescript ecosystem"
    },
    {
      "description": "Group build, lint, and formatting tool bumps together",
      "matchManagers": ["npm"],
      "matchPackageNames": ["oxfmt", "oxlint", "turbo", "unplugin-dts", "vite"],
      "groupName": "build and lint tooling"
    },
    {
      "description": "Group runtime library bumps together",
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "excludePackageNames": ["next", "react", "react-dom"],
      "groupName": "runtime libraries"
    },
    {
      "description": "Group app and edge proxy image bumps together",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchPackageNames": ["caddy"],
      "groupName": "docker web infrastructure"
    },
    {
      "description": "Group backing service image bumps together",
      "matchManagers": ["docker-compose"],
      "matchPackageNames": [
        "chrislusf/seaweedfs",
        "clickhouse/clickhouse-server",
        "postgres",
        "rabbitmq"
      ],
      "groupName": "docker backing services"
    },
    {
      "description": "Group mise tool versions (node + pnpm)",
      "matchManagers": ["mise"],
      "groupName": "mise tools"
    }
  ]
}
