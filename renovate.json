{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "schedule": ["before 9am on monday"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on monday"]
  },
  "packageRules": [
    {
      "description": "Group all non-major Docker image bumps (Dockerfiles + compose) into one PR",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "docker images (non-major)"
    },
    {
      "description": "Keep major Docker bumps separate so they get reviewed individually",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["docker", "major"]
    },
    {
      "description": "Group non-major pnpm devDependency bumps across the workspace",
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "pnpm dev dependencies"
    },
    {
      "description": "Group mise tool versions (node + pnpm)",
      "matchManagers": ["mise"],
      "groupName": "mise tools"
    }
  ]
}
